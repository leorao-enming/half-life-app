{
  "expo": {
    "name": "half-life-app",
    "slug": "half-life-app",
    "scheme": "halflifeapp",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "assets/**"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leorao.halflifeapp",
      "newArchEnabled": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "Half-Life needs to read your steps and activity for your bio-hacking dashboard.",
        "NSHealthUpdateUsageDescription": "Half-Life needs to log your caffeine and sugar intake to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "newArchEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-splash-screen",
      [
        "react-native-health",
        {
          "healthSharePermission": "Half-Life needs to read your health data to track your fitness.",
          "healthUpdatePermission": "Half-Life needs to sync your health data."
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false,
            "useFrameworks": "static"
          },
          "android": {
            "newArchEnabled": false
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "16d273bf-b037-436d-a46a-08b3afa2fb6c"
      }
    }
  }
}
